function renderRadarView(){
  const pick=document.getElementById('radPick');
  pick.innerHTML='';

  // Group by series for compact display
  const groups={};
  SEATS.forEach(s=>{
    const key=s.series;
    if(!groups[key]) groups[key]={series:s.series,color:s.color,seats:[],tier:s.tier};
    groups[key].seats.push(s);
  });

  Object.values(groups).sort((a,b)=>a.tier-b.tier).forEach(g=>{
    g.seats.forEach(s=>{
      const btn=document.createElement('button');
      btn.className='rad-pick-btn'+(radarList.includes(s.id)?' active':'');
      const shortPn=s.pn.replace('SA','').slice(0,8);
      btn.textContent=s.series+(g.seats.length>1?' ·'+shortPn:'');
      if(radarList.includes(s.id)){
        btn.style.cssText=`border-color:${s.color};color:${s.color};background:${s.color}18;`;
      }
      btn.onclick=()=>{
        if(radarList.includes(s.id)){
          radarList=radarList.filter(x=>x!==s.id);
        } else {
          if(radarList.length>=4){showToast('Максимум 4 моделі');return;}
          radarList.push(s.id);
        }
        renderRadarView();
      };
      pick.appendChild(btn);
    });
  });

  const box=document.getElementById('radBox');
  const leg=document.getElementById('radLegend');
  leg.innerHTML='';

  if(!radarList.length){
    box.innerHTML='<div style="font-size:.65rem;color:var(--tx3);letter-spacing:1.5px;text-transform:uppercase;text-align:center">Оберіть моделі вище</div>';
    return;
  }

  const seats=radarList.map(id=>SEATS.find(x=>x.id===id)).filter(Boolean);
  const colors=seats.map((s,i)=>RADAR_COLORS[i]);

  const canvasSize=Math.min(340,window.innerWidth-80);
  box.innerHTML=`
    <div class="rad-canvas-title">${seats.map(s=>s.series).join(' · ')}</div>
    <canvas id="bigRadarCanvas" width="${canvasSize}" height="${canvasSize}"></canvas>`;

  // Draw after DOM updates
  setTimeout(()=>{
    const cv=document.getElementById('bigRadarCanvas');
    if(cv) drawBigRadar(cv, seats, colors);
  }, 50);

  // Legend
  seats.forEach((s,i)=>{
    const item=document.createElement('div');
    item.className='rad-leg-item';
    item.style.marginBottom='10px';
    item.innerHTML=`
      <div class="rad-leg-dot" style="background:${colors[i]}"></div>
      <div style="flex:1">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:.95rem;letter-spacing:1px;color:${colors[i]}">${s.series}</div>
        <div style="font-size:.6rem;color:var(--tx3);font-family:'DM Mono',monospace">${s.pn}</div>
      </div>`;
    leg.appendChild(item);

    RADAR_AXES.forEach((ax,j)=>{
      const ri=document.createElement('div');
      ri.style.cssText='display:flex;align-items:center;gap:8px;margin:2px 0 2px 14px;';
      const barW=Math.round(s.radar[ax]/10*80);
      ri.innerHTML=`
        <div style="font-size:.6rem;color:var(--tx2);width:90px;flex-shrink:0">${RADAR_LABELS[j]}</div>
        <div style="flex:1;height:4px;background:var(--br);border-radius:2px;overflow:hidden">
          <div style="height:4px;width:${barW}%;background:${colors[i]};border-radius:2px;transition:width .3s"></div>
        </div>
        <div style="font-family:'DM Mono',monospace;font-size:.65rem;color:${colors[i]};width:28px;text-align:right">${s.radar[ax]}/10</div>`;
      leg.appendChild(ri);
    });

    if(i<seats.length-1){
      const sep=document.createElement('div');
      sep.style.cssText='height:1px;background:var(--br);margin:10px 0;';
      leg.appendChild(sep);
    }
  });
}

