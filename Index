function buildTags(s){
  const f=s.features;
  const ts=[];
  if(f.backRecline) ts.push('<span class="pc-tag on">↺ Нахил</span>');
  if(f.lumbar) ts.push('<span class="pc-tag on">◍ Поперекова</span>');
  if(f.armrests) ts.push('<span class="pc-tag on">↑ Підлокітники</span>');
  if(f.swivel) ts.push('<span class="pc-tag sp">🔄 Поворот</span>');
  if(f.isolator) ts.push('<span class="pc-tag on">🛡 Ізолятор</span>');
  if(f.lateralIso) ts.push('<span class="pc-tag sp">↔ Бічний ізол.</span>');
  if(f.heat) ts.push('<span class="pc-tag sp">🔥 Підігрів</span>');
  if(f.vent) ts.push('<span class="pc-tag sp">💨 Вент.</span>');
  if(f.autoWeight) ts.push('<span class="pc-tag sp">⚡ Авто рег.</span>');
  if(f.presence) ts.push('<span class="pc-tag on">👤 Датчик</span>');
  if(f.adaptor) ts.push('<span class="pc-tag on">🔩 Adaptor</span>');
  return ts.join('');
}

// ═══════════════════════════════════════════
// MINI RADAR (canvas)
// ═══════════════════════════════════════════
function drawMiniRadar(canvas, seat){
  const ctx=canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  const cx=W/2, cy=H/2, R=42;
  const n=RADAR_AXES.length;
  ctx.clearRect(0,0,W,H);

  // Grid rings
  for(let r=2;r<=10;r+=2){
    ctx.beginPath();
    for(let i=0;i<n;i++){
      const a=i*2*Math.PI/n - Math.PI/2;
      const x=cx+Math.cos(a)*R*(r/10);
      const y=cy+Math.sin(a)*R*(r/10);
      i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
    }
    ctx.closePath();
    ctx.strokeStyle='rgba(255,255,255,0.06)';
    ctx.lineWidth=0.7;
    ctx.stroke();
  }

  // Axes
  for(let i=0;i<n;i++){
    const a=i*2*Math.PI/n - Math.PI/2;
    ctx.beginPath();
    ctx.moveTo(cx,cy);
    ctx.lineTo(cx+Math.cos(a)*R, cy+Math.sin(a)*R);
    ctx.strokeStyle='rgba(255,255,255,0.06)';
    ctx.lineWidth=0.7;
    ctx.stroke();
  }

  // Data
  const c=seat.color;
  ctx.beginPath();
  RADAR_AXES.forEach((ax,i)=>{
    const val=seat.radar[ax]/10;
    const a=i*2*Math.PI/n - Math.PI/2;
    const x=cx+Math.cos(a)*R*val;
    const y=cy+Math.sin(a)*R*val;
    i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
  });
  ctx.closePath();
  ctx.fillStyle=c+'33';
  ctx.fill();
  ctx.strokeStyle=c+'cc';
  ctx.lineWidth=1.5;
  ctx.stroke();
}

// ═══════════════════════════════════════════
// DUAL PRICE SLIDER
// ═══════════════════════════════════════════
const _pricedSeats=SEATS.filter(s=>s.price>0);
const PRICE_MIN_GLOBAL=Math.floor(Math.min(..._pricedSeats.map(s=>s.price))/100)*100;
const PRICE_MAX_GLOBAL=Math.ceil(Math.max(..._pricedSeats.map(s=>s.price))/1000)*1000;

function syncPriceSliders(){
  const elMin=document.getElementById('priceMin');
  const elMax=document.getElementById('priceMax');
  let vMin=+elMin.value;
  let vMax=+elMax.value;
  const gap=1000; // мін. відстань між повзунками
  if(vMin>vMax-gap){
    if(document.activeElement===elMin) vMin=vMax-gap;
    else vMax=vMin+gap;
    elMin.value=vMin;
    elMax.value=vMax;
  }
  updatePriceUI(vMin,vMax);
  applyFilters();
}

function updatePriceUI(vMin,vMax){
  const pct=(v,mn,mx)=>((v-mn)/(mx-mn)*100).toFixed(2);
  const fill=document.getElementById('priceRangeFill');
  fill.style.left=pct(vMin,PRICE_MIN_GLOBAL,PRICE_MAX_GLOBAL)+'%';
  fill.style.right=(100-pct(vMax,PRICE_MIN_GLOBAL,PRICE_MAX_GLOBAL))+'%';
  document.getElementById('priceLblMin').textContent=vMin.toLocaleString('uk-UA')+' ₴';
  document.getElementById('priceLblMax').textContent=vMax.toLocaleString('uk-UA')+' ₴';
}

