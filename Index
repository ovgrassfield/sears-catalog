function roiCalc(){
  const ops     =+document.getElementById('roi-ops').value;
  const days    =+document.getElementById('roi-days').value;
  const hrs     =+document.getElementById('roi-hrs').value;
  const wage    =+document.getElementById('roi-wage').value;
  const price   =+document.getElementById('roi-price').value;
  const prodPct =+document.getElementById('roi-prod').value;
  const sickOld =+document.getElementById('roi-sick-old').value;
  const sickNew =+document.getElementById('roi-sick-new').value;

  document.getElementById('roi-lbl-ops').textContent=ops;
  document.getElementById('roi-lbl-days').textContent=days;
  document.getElementById('roi-lbl-hrs').textContent=hrs;
  document.getElementById('roi-lbl-wage').textContent=wage;
  document.getElementById('roi-lbl-price').textContent=price.toLocaleString('uk-UA');
  document.getElementById('roi-lbl-prod').textContent=prodPct;
  document.getElementById('roi-lbl-sick-old').textContent=sickOld;
  document.getElementById('roi-lbl-sick-new').textContent=sickNew;

  const totalInvest  =ops*price;
  const annualWage   =ops*days*hrs*wage;
  const prodSavings  =annualWage*(prodPct/100);
  const sickSavings  =Math.max(0,sickOld-sickNew)*ops*hrs*wage;
  const errSavings   =prodSavings*0.07;
  const totalSave    =prodSavings+sickSavings+errSavings;
  const paybackM     =totalSave>0?(totalInvest/totalSave)*12:Infinity;
  const roi3yr       =totalSave>0?((totalSave*3-totalInvest)/totalInvest)*100:0;

  document.getElementById('roi-m-invest').textContent=roiUah(totalInvest);
  document.getElementById('roi-m-save').textContent=roiUah(totalSave);
  document.getElementById('roi-m-payback').textContent=paybackM<120?Math.round(paybackM)+' міс.':'>10р.';
  document.getElementById('roi-m-roi').textContent='+'+Math.round(roi3yr)+'%';
  document.getElementById('roi-b-prod').textContent=roiUah(prodSavings);
  document.getElementById('roi-b-sick').textContent=roiUah(sickSavings);
  document.getElementById('roi-b-err').textContent=roiUah(errSavings);
  document.getElementById('roi-b-cost').textContent='−'+roiUah(totalInvest);
  document.getElementById('roi-b-net').textContent=roiUah(totalSave);
  document.getElementById('roi-bp-total').textContent='Всього: '+roiUah(totalSave)+'/рік';

  const pbPct=Math.min(100,(paybackM/36)*100);
  document.getElementById('roi-pb-fill').style.width=pbPct.toFixed(1)+'%';
  document.getElementById('roi-pb-text').textContent=paybackM<120?'Окупність за '+Math.round(paybackM)+' міс.':'Понад 10 років';

  roiUpdateChart(totalInvest,totalSave);
  updateFatigueChart();
}

