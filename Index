  if(!bar) return;
  const chips=[];
  const suspChecked=[...document.querySelectorAll('#suspFilters input:checked')];
  suspChecked.forEach(i=>{
    const lbl=i.closest('label').querySelector('.fchk-lbl').textContent;
    chips.push({label:'Підвіска: '+lbl,clear:()=>{i.checked=false;applyFilters();}});
  });
  const tierChecked=[...document.querySelectorAll('#tierFilters input:checked')];
  tierChecked.forEach(i=>{
    const lbl=i.closest('label').querySelector('.fchk-lbl').textContent;
    chips.push({label:'Рівень: '+lbl,clear:()=>{i.checked=false;applyFilters();}});
  });
  [...activeFeatFilters].forEach(f=>{
    const btn=document.querySelector(`.ff-btn[data-feat="${f}"]`);
    if(btn) chips.push({label:btn.textContent.trim(),clear:()=>{activeFeatFilters.delete(f);btn.classList.remove('on');applyFilters();}});
  });
  const minStroke=+document.getElementById('strokeRange').value;
  if(minStroke>100) chips.push({label:`Хід ≥ ${minStroke}мм`,clear:()=>{document.getElementById('strokeRange').value=100;document.getElementById('strokeLbl').textContent='≥ 100мм';applyFilters();}});
  const pMin=+document.getElementById('priceMin').value;
  const pMax=+document.getElementById('priceMax').value;
  if(pMin>PRICE_MIN_GLOBAL||pMax<PRICE_MAX_GLOBAL){
    chips.push({label:`${Math.round(pMin/1000)}к–${Math.round(pMax/1000)}к ₴`,clear:()=>{document.getElementById('priceMin').value=PRICE_MIN_GLOBAL;document.getElementById('priceMax').value=PRICE_MAX_GLOBAL;updatePriceUI(PRICE_MIN_GLOBAL,PRICE_MAX_GLOBAL);applyFilters();}});
  }
  if(document.getElementById('filterInStock').checked) chips.push({label:'В наявності',clear:()=>{document.getElementById('filterInStock').checked=false;applyFilters();}});
  if(document.getElementById('filterOnOrder').checked) chips.push({label:'Під замовлення',clear:()=>{document.getElementById('filterOnOrder').checked=false;applyFilters();}});
  const q=document.getElementById('sbSearch').value;
  if(q) chips.push({label:`Пошук: "${q}"`,clear:()=>{document.getElementById('sbSearch').value='';applyFilters();}});

  bar.innerHTML=chips.map((c,i)=>
    `<span class="af-chip">${c.label}<button class="af-chip-x" onclick="__afClear(${i})">✕</button></span>`
  ).join('');
  window.__afClear=(i)=>chips[i].clear();
}

function applyFilters(){
  const {suspChecked,tierChecked,q,minStroke,stockIn,stockOrder,priceMin,priceMax}=getActiveFilters();
  const sortVal=document.getElementById('sortSel').value;

  let filtered=[...SEATS];
  if(suspChecked.length) filtered=filtered.filter(s=>suspChecked.includes(s.susp));
  if(tierChecked.length) filtered=filtered.filter(s=>tierChecked.includes(s.tier));
  if(activeFeatFilters.size) filtered=filtered.filter(s=>[...activeFeatFilters].every(f=>s.features[f]));
  if(q) filtered=filtered.filter(s=>(s.series+s.pn+s.app+s.suspLabel).toLowerCase().includes(q));
  filtered=filtered.filter(s=>s.stroke>=minStroke);

  // Price range — seats with price=0 shown as "За запитом", excluded only if slider moved
  const priceFiltered=priceMin>PRICE_MIN_GLOBAL||priceMax<PRICE_MAX_GLOBAL;
  if(priceFiltered){
    filtered=filtered.filter(s=>s.price===0||(s.price>=priceMin&&s.price<=priceMax));
  }

  // Stock filter
  if(stockIn||stockOrder){
    filtered=filtered.filter(s=>(stockIn&&s.inStock)||(stockOrder&&!s.inStock));
  }

  filtered.sort((a,b)=>{
    if(sortVal==='tier') return a.tier-b.tier;
    if(sortVal==='tier-desc') return b.tier-a.tier;
    if(sortVal==='price') return a.price-b.price;
    if(sortVal==='price-desc') return b.price-a.price;
    if(sortVal==='stock') return (b.inStock?1:0)-(a.inStock?1:0);
    if(sortVal==='stroke') return a.stroke-b.stroke;
    if(sortVal==='stroke-desc') return b.stroke-a.stroke;
    if(sortVal==='series') return a.series.localeCompare(b.series);
    return 0;
  });

  document.getElementById('visibleCount').textContent=filtered.length;
  document.getElementById('emptyState').style.display=filtered.length?'none':'block';
  renderCards(filtered);
  if(gridMode==='list') document.getElementById('cardsGrid').classList.add('list');
  renderActiveFilters();
}

function toggleFeat(btn){
  const f=btn.dataset.feat;
  if(activeFeatFilters.has(f)){activeFeatFilters.delete(f);btn.classList.remove('on');}
  else{activeFeatFilters.add(f);btn.classList.add('on');}
  applyFilters();
}

function resetFilters(){
  document.querySelectorAll('#suspFilters input,#tierFilters input').forEach(i=>i.checked=false);
  document.getElementById('sbSearch').value='';
  document.getElementById('strokeRange').value=100;
  document.getElementById('strokeLbl').textContent='≥ 100мм';
  document.getElementById('filterInStock').checked=false;
  document.getElementById('filterOnOrder').checked=false;
  document.getElementById('priceMin').value=PRICE_MIN_GLOBAL;
  document.getElementById('priceMax').value=PRICE_MAX_GLOBAL;
  updatePriceUI(PRICE_MIN_GLOBAL,PRICE_MAX_GLOBAL);
  activeFeatFilters.clear();
  document.querySelectorAll('.ff-btn').forEach(b=>b.classList.remove('on'));
  applyFilters();
}

function updateStrokeLabel(){
  document.getElementById('strokeLbl').textContent='≥ '+document.getElementById('strokeRange').value+'мм';
}

