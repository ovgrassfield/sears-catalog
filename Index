// BIG RADAR (compare / radar view)
// ═══════════════════════════════════════════
function drawBigRadar(canvas, seatArr, colors){
  const ctx=canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  const cx=W/2, cy=H/2, R=Math.min(W,H)/2-18;
  const n=RADAR_AXES.length;
  ctx.clearRect(0,0,W,H);

  // Grid
  for(let r=2;r<=10;r+=2){
    ctx.beginPath();
    for(let i=0;i<n;i++){
      const a=i*2*Math.PI/n-Math.PI/2;
      const rr=R*(r/10);
      i===0?ctx.moveTo(cx+Math.cos(a)*rr,cy+Math.sin(a)*rr):ctx.lineTo(cx+Math.cos(a)*rr,cy+Math.sin(a)*rr);
    }
    ctx.closePath();
    ctx.strokeStyle=r===10?'rgba(255,255,255,0.12)':'rgba(255,255,255,0.05)';
    ctx.lineWidth=r===10?1:0.7;
    ctx.stroke();
  }

  // Axes + labels
  for(let i=0;i<n;i++){
    const a=i*2*Math.PI/n-Math.PI/2;
    ctx.beginPath();
    ctx.moveTo(cx,cy);
    ctx.lineTo(cx+Math.cos(a)*R,cy+Math.sin(a)*R);
    ctx.strokeStyle='rgba(255,255,255,0.08)';
    ctx.lineWidth=0.8;
    ctx.stroke();

    // Label
    const lx=cx+Math.cos(a)*(R+12);
    const ly=cy+Math.sin(a)*(R+12);
    ctx.font='bold 7px Syne,sans-serif';
    ctx.fillStyle='rgba(120,140,170,0.8)';
    ctx.textAlign=lx>cx+2?'left':lx<cx-2?'right':'center';
    ctx.textBaseline=ly>cy+2?'top':ly<cy-2?'bottom':'middle';
    ctx.fillText(RADAR_LABELS[i],lx,ly);
  }

  // Data areas
  seatArr.forEach((s,si)=>{
    const c=colors[si]||s.color;
    ctx.beginPath();
    RADAR_AXES.forEach((ax,i)=>{
      const val=s.radar[ax]/10;
      const a=i*2*Math.PI/n-Math.PI/2;
      const x=cx+Math.cos(a)*R*val, y=cy+Math.sin(a)*R*val;
      i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
    });
    ctx.closePath();
    ctx.fillStyle=c+'28';
    ctx.fill();
    ctx.strokeStyle=c+'cc';
    ctx.lineWidth=2;
    ctx.stroke();

    // Dots
    RADAR_AXES.forEach((ax,i)=>{
      const val=s.radar[ax]/10;
      const a=i*2*Math.PI/n-Math.PI/2;
      ctx.beginPath();
      ctx.arc(cx+Math.cos(a)*R*val,cy+Math.sin(a)*R*val,3,0,Math.PI*2);
      ctx.fillStyle=c;
      ctx.fill();
    });
  });
}

