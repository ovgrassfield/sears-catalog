<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no,viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#06080c">
<title>Sears Seating — Повний інтерактивний каталог</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
/* ═══════════════════════════════════════════
   TOKENS
═══════════════════════════════════════════ */
:root{
  --bg:#06080c; --s1:#0d1018; --s2:#131720; --s3:#181d28;
  --br:#1c2130; --br2:#232a3a; --br3:#2a3347;
  --tx:#d8e0f0; --tx2:#7a8ba8; --tx3:#364257;
  --a:#00e5c9; --ao:#ff6930; --ap:#a78bfa;
  --t1:#475569; --t2:#1e5799; --t3:#0f766e;
  --t4:#6d28d9; --t5:#c2410c; --t6:#b91c1c;
  --sm:#64748b; --sc:#3b82f6; --sa:#06b6d4;
  --sl:#10b981; --sw:#14b8a6; --sv:#a78bfa; --sr:#f87171;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--tx);font-family:'Syne',sans-serif;min-height:100vh;overflow-x:hidden;}

/* ─ HEADER ─ */
.hdr{height:56px;display:flex;align-items:center;justify-content:space-between;padding:0 28px;border-bottom:1px solid var(--br);position:sticky;top:0;z-index:200;background:rgba(6,8,12,.9);backdrop-filter:blur(14px);gap:12px;}
.hdr-brand{display:flex;align-items:center;gap:10px;}
.hdr-logo{width:28px;height:28px;flex-shrink:0;}
.hdr-title{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:3px;white-space:nowrap;}
.hdr-sub{font-size:.6rem;color:var(--tx3);letter-spacing:1.5px;text-transform:uppercase;}

/* Mode tabs */
.mode-tabs{display:flex;gap:2px;background:var(--s1);border-radius:8px;padding:3px;}
.mode-tab{padding:5px 14px;border-radius:6px;border:none;background:transparent;color:var(--tx2);font-family:'Syne',sans-serif;font-size:.72rem;font-weight:600;cursor:pointer;transition:all .18s;white-space:nowrap;letter-spacing:.5px;}
.mode-tab:hover{color:var(--tx);}
.mode-tab.active{background:var(--s3);color:var(--a);box-shadow:0 1px 8px rgba(0,229,201,.12);}

/* Compare counter */
.cmp-counter{display:flex;align-items:center;gap:8px;font-size:.7rem;color:var(--tx2);}
.cmp-count{font-family:'Bebas Neue',sans-serif;font-size:1.2rem;color:var(--a);line-height:1;}
.cmp-btn{padding:5px 12px;border-radius:6px;border:1px solid var(--a);background:transparent;color:var(--a);font-family:'Syne',sans-serif;font-size:.7rem;font-weight:600;cursor:pointer;transition:all .18s;}
.cmp-btn:hover{background:var(--a);color:#000;}
.cmp-btn:disabled{opacity:.3;pointer-events:none;}

/* ─ LAYOUT ─ */
.app{display:flex;min-height:calc(100vh - 56px);}

/* ─ SIDEBAR ─ */
.sidebar{width:230px;flex-shrink:0;border-right:1px solid var(--br);padding:18px 14px;display:flex;flex-direction:column;gap:16px;overflow-y:auto;max-height:calc(100vh - 56px);position:sticky;top:56px;}
.sb-section{display:flex;flex-direction:column;gap:6px;}
.sb-lbl{font-size:.58rem;color:var(--tx3);letter-spacing:2px;text-transform:uppercase;margin-bottom:2px;}
.sb-search{background:var(--s2);border:1px solid var(--br2);border-radius:7px;padding:7px 12px;color:var(--tx);font-family:'Syne',sans-serif;font-size:.75rem;outline:none;width:100%;transition:border-color .2s;}
.sb-search:focus{border-color:var(--a);}
.sb-search::placeholder{color:var(--tx3);}

.fgroup{display:flex;flex-direction:column;gap:4px;}
.fchk{display:flex;align-items:center;gap:7px;cursor:pointer;padding:3px 6px;border-radius:5px;transition:background .15s;}
.fchk:hover{background:var(--s2);}
.fchk input{accent-color:var(--a);width:13px;height:13px;flex-shrink:0;}
.fchk-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.fchk-lbl{font-size:.7rem;color:var(--tx2);}

.feat-filter{display:flex;flex-wrap:wrap;gap:5px;}
.ff-btn{padding:3px 9px;border-radius:12px;border:1px solid var(--br2);background:transparent;color:var(--tx3);font-family:'Syne',sans-serif;font-size:.62rem;font-weight:500;cursor:pointer;transition:all .15s;}
.ff-btn:hover{border-color:var(--a);color:var(--a);}
.ff-btn.on{background:rgba(0,229,201,.1);border-color:var(--a);color:var(--a);}

.reset-btn{padding:6px 12px;border-radius:6px;border:1px solid var(--br2);background:transparent;color:var(--tx3);font-family:'Syne',sans-serif;font-size:.68rem;cursor:pointer;transition:all .18s;width:100%;}
.reset-btn:hover{border-color:var(--ao);color:var(--ao);}

/* ─ MAIN ─ */
.main{flex:1;padding:20px 24px;overflow-y:auto;max-height:calc(100vh - 56px);}

/* ─ CATALOG VIEW ─ */
#catalogView{}
.cat-toolbar{display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap;}
.cat-info{font-size:.7rem;color:var(--tx2);}
.cat-info span{color:var(--a);font-weight:700;}
.sort-sel{background:var(--s2);border:1px solid var(--br2);border-radius:6px;padding:5px 10px;color:var(--tx);font-family:'Syne',sans-serif;font-size:.7rem;outline:none;cursor:pointer;}
.view-toggle{display:flex;gap:2px;margin-left:auto;}
.vt-btn{width:28px;height:28px;border-radius:5px;border:1px solid var(--br2);background:transparent;color:var(--tx3);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;font-size:.85rem;}
.vt-btn.active{background:var(--s3);border-color:var(--br3);color:var(--tx);}

/* Card grid */
.cards-grid{display:grid;gap:12px;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));}
.cards-grid.list{grid-template-columns:1fr;}

/* Product Card */
.pcard{background:var(--s1);border:1px solid var(--br);border-radius:12px;overflow:hidden;transition:transform .2s,box-shadow .2s,border-color .2s;cursor:pointer;animation:fadeUp .3s ease both;position:relative;}
.pcard::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--tc,#333);}
.pcard:hover{transform:translateY(-3px);box-shadow:0 16px 40px rgba(0,0,0,.5);border-color:var(--tc,var(--br3));}
.pcard.in-compare{border-color:var(--a);box-shadow:0 0 0 1px var(--a);}
.pcard.hidden{display:none;}

@keyframes fadeUp{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}

.pc-head{padding:14px 14px 10px;display:flex;align-items:flex-start;justify-content:space-between;gap:8px;}
.pc-series{font-family:'Bebas Neue',sans-serif;font-size:1.8rem;letter-spacing:1px;line-height:1;}
.pc-tier{padding:2px 8px;border-radius:4px;font-size:.58rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;background:var(--tc);color:#fff;white-space:nowrap;margin-top:4px;}
.pc-pn{padding:0 14px 8px;font-family:'DM Mono',monospace;font-size:.65rem;color:var(--tx2);}
.pc-susp{margin:0 14px 10px;display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:6px;background:var(--sc-bg);border:1px solid var(--sc-br);}
.pc-susp-dot{width:7px;height:7px;border-radius:50%;background:var(--sc-c);flex-shrink:0;}
.pc-susp-lbl{font-size:.65rem;font-weight:700;color:var(--sc-c);}
.pc-susp-stroke{font-size:.6rem;color:var(--tx2);margin-left:3px;}

/* Mini radar in card */
.pc-photo{width:calc(100% - 0px);height:140px;overflow:hidden;border-radius:8px;margin:6px 0 2px;background:var(--s2);border:1px solid var(--br);display:flex;align-items:center;justify-content:center;}
.pc-photo img{width:100%;height:100%;object-fit:contain;object-position:center;transition:transform .3s ease;padding:6px;}
.pcard:hover .pc-photo img{transform:scale(1.05);}
.pc-photo-empty{opacity:.35;}
.pc-photo-placeholder{display:flex;flex-direction:column;align-items:center;gap:4px;}
.pc-photo-icon{font-size:2rem;line-height:1;}
.pc-photo-lbl{font-size:.6rem;color:var(--tx3);letter-spacing:1px;}
.pc-radar{padding:8px 14px 2px;display:flex;justify-content:center;}
canvas.mini-radar{display:block;}

.pc-specs{padding:4px 14px 10px;display:grid;grid-template-columns:1fr 1fr;gap:5px;}
.pc-spec{}
.pc-spec-l{font-size:.55rem;color:var(--tx3);text-transform:uppercase;letter-spacing:.8px;}
.pc-spec-v{font-size:.72rem;font-weight:600;}

.pc-tags{padding:0 14px 10px;display:flex;flex-wrap:wrap;gap:4px;}
.pc-tag{font-size:.58rem;padding:2px 7px;border-radius:4px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);color:var(--tx3);}
.pc-tag.on{background:rgba(0,229,201,.07);border-color:rgba(0,229,201,.18);color:var(--a);}
.pc-tag.sp{background:rgba(255,105,48,.07);border-color:rgba(255,105,48,.18);color:var(--ao);}

.pc-foot{padding:8px 14px;background:var(--s2);border-top:1px solid var(--br);display:flex;align-items:center;justify-content:space-between;gap:8px;}
.pc-app{font-size:.62rem;color:var(--tx2);}
.pc-add{width:24px;height:24px;border-radius:5px;border:1px solid var(--br3);background:transparent;color:var(--tx3);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;font-size:.9rem;flex-shrink:0;}
.pc-add:hover{border-color:var(--a);color:var(--a);background:rgba(0,229,201,.08);}
.pc-add.added{border-color:var(--a);color:var(--a);background:rgba(0,229,201,.12);}

/* Price & stock row */
.pc-commerce{padding:6px 14px 8px;display:flex;align-items:center;justify-content:space-between;gap:6px;border-top:1px solid var(--br);}
.pc-price{font-family:'Bebas Neue',sans-serif;font-size:1.15rem;letter-spacing:.5px;color:var(--tx);line-height:1;}
.pc-price-sub{font-size:.5rem;color:var(--tx3);letter-spacing:.5px;font-family:'Syne',sans-serif;font-weight:400;}
.pc-stock{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:5px;font-size:.58rem;font-weight:700;letter-spacing:.5px;white-space:nowrap;}
.pc-stock.yes{background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.25);color:#10b981;}
.pc-stock.no{background:rgba(251,146,60,.08);border:1px solid rgba(251,146,60,.2);color:#fb923c;}
.pc-stock-dot{width:5px;height:5px;border-radius:50%;background:currentColor;flex-shrink:0;}

/* List mode card */
.cards-grid.list .pcard{display:flex;align-items:center;}
.cards-grid.list .pc-head{width:140px;flex-shrink:0;border-right:1px solid var(--br);}
.cards-grid.list .pc-pn{width:140px;flex-shrink:0;}
.cards-grid.list .pc-susp{margin-top:0;margin-bottom:0;}
.cards-grid.list .pc-radar{display:none;}
.cards-grid.list .pc-photo{display:none;}
.cards-grid.list .pc-specs{flex:1;grid-template-columns:repeat(4,1fr);}
.cards-grid.list .pc-tags{flex:0 0 180px;}
.cards-grid.list .pc-foot{flex-shrink:0;border-top:none;border-left:1px solid var(--br);}
.cards-grid.list .pc-commerce{flex-shrink:0;border-top:none;border-left:1px solid var(--br);flex-direction:column;align-items:flex-start;padding:8px 14px;}
.cards-grid.list .pcard::after{top:0;left:0;right:auto;bottom:0;width:2px;height:auto;}

/* ─ COMPARE VIEW ─ */
#compareView{display:none;}
.cmp-header{margin-bottom:20px;}
.cmp-header h2{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:3px;}
.cmp-header p{font-size:.7rem;color:var(--tx2);margin-top:4px;}

.cmp-slots{display:grid;gap:12px;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));margin-bottom:28px;}
.cmp-slot{background:var(--s1);border:1px dashed var(--br3);border-radius:10px;min-height:80px;display:flex;align-items:center;justify-content:center;font-size:.7rem;color:var(--tx3);gap:7px;padding:16px;}
.cmp-slot.filled{border-style:solid;border-color:var(--br2);align-items:flex-start;padding:0;overflow:hidden;flex-direction:column;}
.cmp-slot-empty-icon{font-size:1.2rem;opacity:.4;}

.cmp-panel{display:none;}
.cmp-panel.visible{display:block;}

/* Comparison table */
.cmp-table{width:100%;border-collapse:separate;border-spacing:0;}
.cmp-table th{background:var(--s2);padding:10px 12px;font-size:.62rem;color:var(--tx2);text-align:left;border-bottom:1px solid var(--br);white-space:nowrap;letter-spacing:.5px;text-transform:uppercase;font-weight:600;}
.cmp-table th.seat-col{text-align:center;font-family:'Bebas Neue',sans-serif;font-size:.9rem;letter-spacing:2px;color:var(--tx);}
.cmp-table td{padding:8px 12px;border-bottom:1px solid rgba(28,33,48,.6);font-size:.72rem;vertical-align:middle;}
.cmp-table td.feat-label{color:var(--tx2);white-space:nowrap;}
.cmp-table td.feat-val{text-align:center;}
.cmp-table tr:hover td{background:rgba(255,255,255,.015);}
.cmp-diff td.feat-val:not(.same){background:rgba(255,105,48,.07);}
.v-yes{color:var(--a);font-size:1rem;font-weight:700;}
.v-no{color:var(--tx3);}
.v-txt{color:var(--tx);font-size:.72rem;}
.radar-row td{padding:14px 12px;}

/* ─ RADAR VIEW ─ */
#radarView{display:none;}
.rad-header{margin-bottom:20px;}
.rad-header h2{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:3px;}
.rad-header p{font-size:.7rem;color:var(--tx2);margin-top:4px;}

.rad-pick{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:24px;}
.rad-pick-btn{padding:5px 12px;border-radius:6px;border:1px solid var(--br2);background:transparent;color:var(--tx2);font-size:.68rem;font-weight:600;cursor:pointer;transition:all .15s;font-family:'Syne',sans-serif;}
.rad-pick-btn:hover{border-color:var(--a);color:var(--a);}
.rad-pick-btn.active{background:rgba(0,229,201,.1);border-color:var(--a);color:var(--a);}

.rad-canvas-wrap{display:flex;align-items:flex-start;gap:32px;flex-wrap:wrap;}
.rad-canvas-box{background:var(--s1);border:1px solid var(--br);border-radius:14px;padding:24px;display:flex;flex-direction:column;align-items:center;gap:14px;}
.rad-canvas-title{font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:2px;}
.rad-legend{display:flex;flex-direction:column;gap:8px;min-width:180px;}
.rad-leg-item{display:flex;align-items:center;gap:10px;}
.rad-leg-dot{width:10px;height:10px;border-radius:50%;}
.rad-leg-lbl{font-size:.68rem;color:var(--tx2);}
.rad-leg-val{margin-left:auto;font-family:'DM Mono',monospace;font-size:.72rem;color:var(--tx);}

/* ─ DETAIL MODAL ─ */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.8);backdrop-filter:blur(8px);z-index:500;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity .2s;}
.modal-overlay.open{opacity:1;pointer-events:all;}
.modal{background:var(--s1);border:1px solid var(--br2);border-radius:16px;width:100%;max-width:680px;max-height:90vh;overflow-y:auto;animation:modalIn .25s ease;}
@keyframes modalIn{from{transform:scale(.95) translateY(10px);opacity:0;}to{transform:scale(1) translateY(0);opacity:1;}}
.modal-head{display:flex;align-items:flex-start;justify-content:space-between;padding:24px 24px 16px;border-bottom:1px solid var(--br);}
.modal-series{font-family:'Bebas Neue',sans-serif;font-size:3rem;letter-spacing:2px;line-height:1;}
.modal-close{width:32px;height:32px;border-radius:8px;border:1px solid var(--br2);background:transparent;color:var(--tx2);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1rem;transition:all .15s;flex-shrink:0;}
.modal-close:hover{border-color:var(--ao);color:var(--ao);}
.modal-body{padding:20px 24px 28px;display:flex;gap:24px;flex-wrap:wrap;}
.modal-left{flex:1;min-width:240px;}
.modal-right{display:flex;flex-direction:column;align-items:center;gap:12px;}
.modal-pn{font-family:'DM Mono',monospace;font-size:.7rem;color:var(--tx2);margin-bottom:10px;}
.modal-desc{font-size:.78rem;color:var(--tx2);line-height:1.6;margin-bottom:14px;}
.modal-specs-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px;}
.ms{background:var(--s2);border:1px solid var(--br);border-radius:7px;padding:9px 12px;}
.ms-l{font-size:.58rem;color:var(--tx3);text-transform:uppercase;letter-spacing:1px;margin-bottom:2px;}
.ms-v{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:.5px;}
.modal-feats{display:flex;flex-wrap:wrap;gap:5px;}
.mf{display:flex;align-items:center;gap:5px;padding:4px 9px;border-radius:5px;font-size:.65rem;border:1px solid var(--br);background:var(--s2);color:var(--tx3);}
.mf.on{background:rgba(0,229,201,.07);border-color:rgba(0,229,201,.2);color:var(--a);}
.mf.sp{background:rgba(255,105,48,.07);border-color:rgba(255,105,48,.2);color:var(--ao);}

/* ─ TOAST ─ */
.toast{position:fixed;bottom:24px;right:24px;background:var(--s3);border:1px solid var(--a);border-radius:8px;padding:10px 16px;font-size:.72rem;color:var(--a);transform:translateY(60px);opacity:0;transition:all .25s;z-index:600;}
.toast.show{transform:translateY(0);opacity:1;}

/* ═══════════════════════════════════════════
   ROI VIEW
═══════════════════════════════════════════ */
#roiView{display:none;}
.roi-header{margin-bottom:20px;}
.roi-header h2{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:3px;}
.roi-header p{font-size:.7rem;color:var(--tx2);margin-top:4px;}

/* Seat selector banner */
.roi-seat-banner{display:flex;align-items:center;gap:12px;padding:12px 16px;border-radius:10px;background:var(--s2);border:1px solid var(--br2);margin-bottom:18px;flex-wrap:wrap;}
.roi-seat-info{flex:1;min-width:0;}
.roi-seat-name{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:1.5px;color:var(--a);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.roi-seat-pn{font-family:'DM Mono',monospace;font-size:.6rem;color:var(--tx3);}
.roi-seat-price{font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:.5px;white-space:nowrap;}
.roi-seat-hint{font-size:.62rem;color:var(--tx3);width:100%;}
.roi-from-catalog{padding:5px 12px;border-radius:6px;border:1px solid var(--ao);background:rgba(255,105,48,.1);color:var(--ao);font-family:'Syne',sans-serif;font-size:.65rem;font-weight:600;cursor:pointer;transition:all .18s;white-space:nowrap;flex-shrink:0;}
.roi-from-catalog:hover{background:var(--ao);color:#000;}

/* ROI grid */
.roi-grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px;}
.roi-panel{background:var(--s1);border:1px solid var(--br);border-radius:12px;padding:18px;position:relative;overflow:hidden;}
.roi-panel::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--a),transparent);}
.roi-panel.orange::before{background:linear-gradient(90deg,var(--ao),transparent);}
.roi-panel-title{font-family:'Bebas Neue',sans-serif;font-size:.85rem;letter-spacing:2px;color:var(--tx);margin-bottom:14px;}
.roi-panel-title span{color:var(--a);}
.roi-panel.orange .roi-panel-title span{color:var(--ao);}

/* ROI fields */
.roi-field{margin-bottom:14px;}
.roi-field:last-child{margin-bottom:0;}
.roi-field-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;}
.roi-field-lbl{font-size:.68rem;color:var(--tx2);font-weight:600;}
.roi-field-val{font-family:'Bebas Neue',sans-serif;font-size:.95rem;letter-spacing:.8px;color:var(--a);}
.roi-field.orange .roi-field-val{color:var(--ao);}
.roi-field input[type=range]{width:100%;accent-color:var(--a);}
.roi-field.orange input[type=range]{accent-color:var(--ao);}

/* Metric cards */
.roi-metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px;}
.roi-mc{background:var(--s2);border:1px solid var(--br);border-radius:10px;padding:14px 12px;}
.roi-mc.hl{border-color:rgba(0,229,201,.25);background:rgba(0,229,201,.06);}
.roi-mc.hlo{border-color:rgba(255,105,48,.22);background:rgba(255,105,48,.06);}
.roi-mc-lbl{font-size:.55rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--tx3);margin-bottom:5px;}
