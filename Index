// ═══════════════════════════════════════════
// FATIGUE CURVE CHART
// Vibrations → Fatigue → Productivity loss per hour
// ═══════════════════════════════════════════
function getFatigueCurve(suspType, totalHrs){
  // Fatigue accumulation model:
  // Each suspension type has a WBV reduction factor.
  // Old seat (mech baseline): productivity starts at 100%, drops linearly+accelerating with fatigue.
  // Better seat: slower fatigue accumulation, less drop.
  const wbvFactors={mech:1.0,cmech:0.85,cair:0.70,lnf:0.50,wide:0.45,vis:0.42,avrs:0.37};
  const wbv=wbvFactors[suspType]||1.0;
  // Gompertz-like fatigue: eff(t) = 1 - fatigueDepth * (1 - e^(-k*wbv*t))^2
  // fatigue starts slow, accelerates after hour 4, then flattens
  const pts=[];
  const hours=Math.max(8, totalHrs);
  for(let h=0;h<=hours;h+=0.5){
    const fatigueFactor=1-Math.exp(-0.12*wbv*h);
    const drop=0.28*wbv*(fatigueFactor*fatigueFactor); // max ~28% drop for mech
    const eff=Math.max(0.60, 1.0-drop);
    pts.push(+(eff*100).toFixed(1));
  }
  return pts;
}

function updateFatigueChart(){
  const hrs=+document.getElementById('roi-hrs').value;
  const ops=+document.getElementById('roi-ops').value;
  const days=+document.getElementById('roi-days').value;
  const wage=+document.getElementById('roi-wage').value;

  // Determine selected suspension type from active button
  const activeBtn=document.querySelector('.roi-susp-btn.active');
  const newSusp=activeBtn?activeBtn.dataset.susp:'lnf';

  const oldCurve=getFatigueCurve('mech',hrs);
  const newCurve=getFatigueCurve(newSusp,hrs);

  // Build labels: every 0.5 hr step up to hrs
  const labels=[];
  for(let h=0;h<=hrs;h+=0.5) labels.push(h%2===0?h+'год':'');

  // Calculate lost effective hours per shift
  const steps=hrs*2; // 0.5h steps
  let oldLost=0,newLost=0;
  for(let i=0;i<=steps;i++){
    oldLost+=(1-(oldCurve[i]||oldCurve[oldCurve.length-1])/100)*0.5;
    newLost+=(1-(newCurve[i]||newCurve[newCurve.length-1])/100)*0.5;
  }
  const savedHrsPerYear=(oldLost-newLost)*ops*days;

  document.getElementById('fatigueOldLost').textContent=oldLost.toFixed(1)+' год/зміну';
  document.getElementById('fatigueNewLost').textContent=newLost.toFixed(1)+' год/зміну';
  document.getElementById('fatigueSaved').textContent=Math.round(savedHrsPerYear)+' год/рік ('+roiUah(savedHrsPerYear*wage)+')';

  // Legend
  const suspNames={mech:'Механічна',cmech:'Компакт.мех.',cair:'Compact Air',lnf:'LNF Air',wide:'Extra Wide LNF',vis:'VIS Ultra-LNF',avrs:'ActiveVRS'};
  const suspColors={mech:'#64748b',cmech:'#3b82f6',cair:'#06b6d4',lnf:'#10b981',wide:'#14b8a6',vis:'#a78bfa',avrs:'#f87171'};
  const leg=document.getElementById('fatigueLegend');
  if(leg) leg.innerHTML=`
    <div class="roi-fatigue-leg"><div class="roi-fatigue-leg-dot" style="background:#64748b"></div>Механічна (базова)</div>
    <div class="roi-fatigue-leg"><div class="roi-fatigue-leg-dot" style="background:${suspColors[newSusp]||'#00e5c9'}"></div>${suspNames[newSusp]||newSusp}</div>`;

  const gridCol='rgba(28,33,48,.8)';
  const tickCol='#3a4560';

  if(fatigueChart){
    fatigueChart.data.labels=labels;
    fatigueChart.data.datasets[0].data=oldCurve.slice(0,labels.length);
    fatigueChart.data.datasets[1].data=newCurve.slice(0,labels.length);
    fatigueChart.data.datasets[1].label=suspNames[newSusp]||newSusp;
    fatigueChart.data.datasets[1].borderColor=suspColors[newSusp]||'#00e5c9';
    fatigueChart.data.datasets[1].backgroundColor=(suspColors[newSusp]||'#00e5c9')+'14';
    fatigueChart.update();
    return;
  }
  const canvas=document.getElementById('fatigueChart');
  if(!canvas) return;
  fatigueChart=new Chart(canvas,{
    type:'line',
    data:{
      labels,
      datasets:[
        {label:'Механічна (базова)',data:oldCurve.slice(0,labels.length),borderColor:'#64748b',backgroundColor:'rgba(100,116,139,0.06)',borderWidth:2,pointRadius:0,fill:true,tension:0.4,borderDash:[5,3]},
        {label:suspNames[newSusp]||newSusp,data:newCurve.slice(0,labels.length),borderColor:suspColors[newSusp]||'#00e5c9',backgroundColor:(suspColors[newSusp]||'#00e5c9')+'14',borderWidth:2.5,pointRadius:0,fill:true,tension:0.4}
      ]
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      interaction:{mode:'index',intersect:false},
      plugins:{
        legend:{display:false},
        tooltip:{backgroundColor:'#0d1018',borderColor:'#1c2130',borderWidth:1,titleColor:'#7a8ba8',bodyColor:'#d8e0f0',titleFont:{family:'Syne',size:10},bodyFont:{family:'DM Mono',size:12},padding:10,
          callbacks:{
            title:items=>'Година '+items[0].label.replace('год',''),
            label:ctx=>ctx.dataset.label+':  '+ctx.parsed.y.toFixed(1)+'% ефективності'
          }
        }
      },
      scales:{
        x:{ticks:{color:tickCol,font:{family:'Syne',size:9},autoSkip:true,maxTicksLimit:8,maxRotation:0,callback:(v,i,all)=>all[i].label||''},grid:{color:gridCol}},
        y:{min:55,max:100,ticks:{color:tickCol,font:{family:'Syne',size:10},callback:v=>v+'%'},grid:{color:gridCol},title:{display:true,text:'Ефективність оператора, %',color:'#364257',font:{family:'Syne',size:9}}}
      }
    }
  });
}

