        <div class="pc-spec"><div class="pc-spec-l">Слайд</div><div class="pc-spec-v">${s.slide}мм</div></div>
        <div class="pc-spec"><div class="pc-spec-l">Оббивка</div><div class="pc-spec-v" style="font-size:.65rem">${s.cushion}</div></div>
        <div class="pc-spec"><div class="pc-spec-l">Рівень</div><div class="pc-spec-v">${s.tier}</div></div>
      </div>
      <div class="pc-tags">${tags}</div>
      <div class="pc-commerce">
        <div>
          <div class="pc-price">${s.price>0?s.price.toLocaleString('uk-UA')+' ₴':'За запитом'}</div>
          <div class="pc-price-sub">${s.price>0?'орієнтовна ціна':'уточніть у менеджера'}</div>
        </div>
        <div class="pc-stock ${s.inStock?'yes':'no'}">
          <div class="pc-stock-dot"></div>
          ${s.inStock?'В наявності':'Під замовлення'}
        </div>
      </div>
      <div class="pc-foot">
        <div class="pc-app">🚜 ${s.app}</div>
        <button class="pc-add${inCmp?' added':''}" onclick="toggleCompare('${s.id}',event)" title="${inCmp?'Видалити':'Додати до порівняння'}">${inCmp?'✓':'+'}</button>
        <button class="pc-add" onclick="roiFromCard('${s.id}',event)" title="Розрахувати ROI" style="border-color:rgba(255,105,48,.3);color:var(--ao)">₴</button>
